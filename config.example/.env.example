# LifeOS Configuration
# Copy this file to config/.env and fill in your values

# ── Core ──
PORT=3001
# DATABASE_PATH=/data/lifeos.db  # Override DB location (default: ./lifeos.db)

# ── Claude PA (Bring Your Own Key) ──
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model override (default: claude-sonnet-4-5-20250929)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Claude Cowork endpoint (optional, for Pro subscribers)
# CLAUDE_COWORK_ENDPOINT=http://localhost:8700

# ── Whoop (health metrics: recovery, sleep, HRV) ──
# OAuth: register app at https://developer.whoop.com/
# Redirect URI: http://localhost:3001/api/health/whoop/callback
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=

# ── Stripe (business revenue tracking) ──
# Get your key from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=

# ── Wise (personal spending tracking) ──
# Token: https://wise.com/user/api-tokens
# Profile ID: https://api.transferwise.com/v1/profiles
# WISE_API_TOKEN=
# WISE_PROFILE_ID=

# ── GitHub (project commit tracking) ──
# Token: https://github.com/settings/tokens
# GITHUB_TOKEN=

# ── Telegram (daily briefings bot) ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Gmail (send emails via PA) ──
# GMAIL_CREDENTIALS_PATH=~/.config/lifeos/gmail-credentials.json
# GMAIL_TOKEN_PATH=~/.config/lifeos/gmail-token.json

# ── Outlook ──
# OUTLOOK_USER_EMAIL=

# ── WhatsApp (message bridge) ──
# WHATSAPP_BRIDGE_PATH=
# WHATSAPP_MCP_URL=http://localhost:8080
# WHATSAPP_DEVICE_DB_PATH=

# ── Soulin Social (social media management) ──
# SOULIN_SOCIAL_URL=http://localhost:3000
