# ════════════════════════════════════════════════════════════════
# Life OS — Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file:  cp .env.example .env
# Then fill in only the integrations you want to use.
# Everything marked (optional) can be left blank.
# ════════════════════════════════════════════════════════════════


# ── SERVER ──────────────────────────────────────────────────────

PORT=3001


# ── AI — Personal Assistant chat ────────────────────────────────
# (optional) Powers the PA chat bar on the dashboard.
# Get your key: https://console.anthropic.com/

ANTHROPIC_API_KEY=


# ── HEALTH — Whoop ──────────────────────────────────────────────
# (optional) Daily sync for recovery, sleep, HRV.
# Register an app: https://developer.whoop.com/
# Redirect URI: http://localhost:3001/api/health/whoop/callback

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=


# ── FINANCE — Stripe ────────────────────────────────────────────
# (optional) Business revenue sync.
# Get your key: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=


# ── FINANCE — Wise ──────────────────────────────────────────────
# (optional) Personal spending sync.
# Get your token: https://wise.com/user/api-tokens
# Get your profile ID: https://api.transferwise.com/v1/profiles

WISE_API_TOKEN=
WISE_PROFILE_ID=


# ── CODE — GitHub ───────────────────────────────────────────────
# (optional) Project commit date tracking.
# Create a token: https://github.com/settings/tokens

GITHUB_TOKEN=


# ── EMAIL — Gmail ───────────────────────────────────────────────
# (optional) Inbox sync and send.
# Create OAuth 2.0 credentials: https://console.cloud.google.com/apis/credentials
# Enable Gmail API. Redirect URI: http://localhost:3001/api/gmail/callback

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=


# ── MESSAGING — Telegram ───────────────────────────────────────
# (optional) Daily briefing bot.
# Create a bot: https://t.me/BotFather

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
