# Anthropic Claude API Key (fallback if Claude Cowork not available)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Claude Cowork Local Endpoint (optional, defaults to http://localhost:8700)
# If your Claude Cowork runs on a different port, update this
CLAUDE_COWORK_ENDPOINT=http://localhost:8700

# Whoop API Token (for health metrics)
# Get your token from: https://app.whoop.com/developer/
WHOOP_API_TOKEN=your_whoop_token_here

# Stripe Secret Key (optional, for business finance)
# Get your key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_key_here

# Wise API Token (optional, for personal spending)
# Get your token from: https://wise.com/user/api-tokens
# Also get your Profile ID from: https://api.transferwise.com/v1/profiles
WISE_API_TOKEN=your_wise_token_here
WISE_PROFILE_ID=your_wise_profile_id_here

# GitHub Token (for project commit dates)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Server Port (optional)
PORT=3000
