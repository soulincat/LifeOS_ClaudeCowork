# Anthropic Claude API Key (fallback if Claude Cowork not available)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Claude Cowork Local Endpoint (optional, defaults to http://localhost:8700)
# If your Claude Cowork runs on a different port, update this
CLAUDE_COWORK_ENDPOINT=http://localhost:8700

# Whoop API (health metrics: recovery, sleep, HRV)
# Option A – OAuth (recommended): register app at https://developer.whoop.com/
#   Set WHOOP_CLIENT_ID and WHOOP_CLIENT_SECRET; redirect URI: http://localhost:3001/api/health/whoop/callback
# Option B – Legacy: set WHOOP_API_TOKEN from https://app.whoop.com/developer/ (if still supported)
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
# Optional: default is http://localhost:PORT/api/health/whoop/callback
# WHOOP_REDIRECT_URI=http://localhost:3001/api/health/whoop/callback
# WHOOP_API_TOKEN=your_whoop_token_here

# Stripe Secret Key (optional, for business finance)
# Get your key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_key_here

# Wise API Token (optional, for personal spending)
# Get your token from: https://wise.com/user/api-tokens
# Also get your Profile ID from: https://api.transferwise.com/v1/profiles
WISE_API_TOKEN=your_wise_token_here
WISE_PROFILE_ID=your_wise_profile_id_here

# GitHub Token (for project commit dates)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Gmail OAuth (inbox sync + send)
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Enable Gmail API, set redirect URI to: http://localhost:3001/api/gmail/callback
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here

# Server Port (optional)
PORT=3000
