# Anthropic Claude API Key (fallback if Claude Cowork not available)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Claude Cowork Local Endpoint (optional, defaults to http://localhost:8700)
# If your Claude Cowork runs on a different port, update this
CLAUDE_COWORK_ENDPOINT=http://localhost:8700

# Server Port (optional)
PORT=3000
